# ============================================
# LinkedIn Authority Mentor — Environment Config
# ============================================
# Copy this file to .env and fill in your values

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Google Sheets ---
# Base64-encoded JSON service account key
# To encode: base64 -w 0 service-account.json
GOOGLE_SHEETS_CREDENTIALS_B64=your-base64-encoded-service-account-json
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_SHEET_NAME=your-google-sheet-name-here

# --- LinkedIn API ---
# Get from https://developer.linkedin.com
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token-here
LINKEDIN_PERSON_URN=urn:li:person:your-person-id-here

# --- Schedule ---
# Days: mon,tue,wed,thu,fri,sat,sun
SCHEDULE_DAYS=mon,wed,fri
SCHEDULE_HOUR=18
SCHEDULE_MINUTE=0
SCHEDULE_TIMEZONE=Asia/Kolkata

# --- Logging ---
LOG_LEVEL=INFO
